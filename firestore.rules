rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; 
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidMachine(data) {
      return data.keys().hasAll(['id', 'product', 'op', 'tag', 'status', 'time', 'order', 'updatedAt']) 
        && data.keys().size() >= 8
        && data.id is string && data.id.size() > 0 && data.id.size() <= 100
        && data.product is string && data.product.size() <= 100
        && data.op is string && data.op.size() <= 100
        && data.tag is string && data.tag.size() <= 100
        && data.status is string && data.status.size() <= 100
        && data.time is string && data.time.size() <= 100
        && data.order is number
        && data.updatedAt is timestamp
        // history is optional, if provided it must be a list
        && (!('history' in data.keys()) || data.history is list);
    }

    match /machines/{machineId} {
      // Allow public reads
      allow read: if true;
      
      // Allow create and update
      allow create: if isValidId(machineId) 
        && isValidMachine(incoming()) 
        && incoming().updatedAt == request.time;
        
      allow update: if isValidId(machineId)
        && isValidMachine(incoming())
        && incoming().updatedAt == request.time;
        // removing affectedKeys restriction as it causes issues when dynamically adding fields (like history)
        
      allow delete: if true;
    }
  }
}
